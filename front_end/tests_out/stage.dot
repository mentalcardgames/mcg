digraph CFG {
  graph [splines=ortho, nodesep=1.0, ranksep=1.0, concentrate=true];
  node [shape=box, fontname="Consolas, 'Courier New', monospace", style=filled, fillcolor="#ffffff", bordercolor="#333333"];
  edge [fontname="Consolas", fontsize=9, arrowsize=0.8];
  entry [shape=point];
  entry -> 0;
  7 -> 1 [xlabel=" Action "];
  0 -> 3 [xlabel=" Action "];
  2 -> 0 [xlabel=" Stage Round Counter "];
  6 -> 7 [xlabel=" Condition "];
  6 -> 5 [xlabel=" Not Condition "];
  3 -> 2 [xlabel=" Not EndCondition "];
  3 -> 4 [xlabel=" EndCondition "];
  4 -> 6 [xlabel=" Action "];
  5 -> 3 [xlabel=" Stage Round Counter "];
}
