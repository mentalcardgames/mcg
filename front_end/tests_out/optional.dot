digraph CFG {
  graph [splines=ortho, nodesep=1.0, ranksep=1.0, concentrate=true];
  node [shape=box, fontname="Consolas, 'Courier New', monospace", style=filled, fillcolor="#ffffff", bordercolor="#333333"];
  edge [fontname="Consolas", fontsize=9, arrowsize=0.8];
  entry [shape=point];
  entry -> 0;
  0 -> 2 [xlabel=" Optional "];
  0 -> 1 [xlabel=" Optional "];
  2 -> 1 [xlabel=" Action "];
}
