digraph FSM {
  rankdir=LR;
  node [shape = circle];
  1 -> 3 [label="EndCondition(UntilRep(Repititions { times: Int(1) }))"];
  3 -> 4 [label="Action(DealMove(DealQuantity(Int(Int(12)), Group(CardPosition(Top(Location(Stock)))), Private, GroupOfPlayerCollection(Location(Location(Hand)), Quantifier(All)))))"];
